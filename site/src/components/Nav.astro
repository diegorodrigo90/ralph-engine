---
import type { Locale } from '../i18n/utils';
import { t, localePath, alternateLang } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const altLang = alternateLang(lang);
const altLabel = altLang === 'pt-br' ? 'PT' : 'EN';
const currentPath = Astro.url.pathname.replace('/pt-br', '') || '/';
---

<header class="nav">
  <div class="container nav-inner">
    <a href={localePath(lang, '/')} class="nav-logo" aria-label="Ralph Engine home">
      <img src="/logo-icon.svg" alt="" width="24" height="24" />
      <span class="nav-logo-text">Ralph Engine</span>
    </a>

    <nav class="nav-desktop" aria-label="Main navigation">
      <ul class="nav-links">
        <li><a href={localePath(lang, '/plugins/')}>{t(lang, 'nav.plugins')}</a></li>
        <li><a href={lang === 'pt-br' ? '/docs/pt-br/getting-started/installation' : '/docs/getting-started/installation'}>{t(lang, 'nav.docs')}</a></li>
        <li>
          <a href="https://github.com/diegorodrigo90/ralph-engine" target="_blank" rel="noopener" class="github-link" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
        </li>
      </ul>
    </nav>

    <div class="nav-actions">
      <button class="search-trigger" aria-label="Search" type="button" id="search-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
        <span class="search-label">Search</span>
        <kbd class="search-kbd" id="search-shortcut"></kbd>
      </button>
      <a href={localePath(altLang, currentPath)} class="locale-switch" aria-label={`Switch to ${altLabel}`}>
        {altLabel}
      </a>
      <button class="theme-toggle" aria-label="Toggle dark mode" type="button">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
        </svg>
      </button>

      {/* Hamburger — mobile only */}
      <button class="hamburger" aria-label="Open menu" type="button">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile menu panel */}
  <div class="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <button class="mobile-close" aria-label="Close menu" type="button">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
      <nav aria-label="Mobile navigation">
        <ul class="mobile-links">
          <li><a href={localePath(lang, '/')}>Home</a></li>
          <li><a href={localePath(lang, '/plugins/')}>{t(lang, 'nav.plugins')}</a></li>
          <li><a href={lang === 'pt-br' ? '/docs/pt-br/getting-started/installation' : '/docs/getting-started/installation'}>{t(lang, 'nav.docs')}</a></li>
          <li>
            <a href="https://github.com/diegorodrigo90/ralph-engine" target="_blank" rel="noopener">
              GitHub
            </a>
          </li>
        </ul>
      </nav>
      <div class="mobile-footer">
        <a href={localePath(altLang, currentPath)} class="locale-switch">{altLabel}</a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  // Theme toggle
  document.querySelector('.theme-toggle')?.addEventListener('click', function () {
    var html = document.documentElement;
    var current = html.dataset.theme;
    var next = current === 'dark' ? 'light' : 'dark';
    html.dataset.theme = next;
    localStorage.setItem('ralph-theme', next);
    localStorage.setItem('vitepress-theme-appearance', next);
  });

  // Show ⌘K on Mac, Ctrl+K on others
  var shortcut = document.getElementById('search-shortcut');
  if (shortcut) {
    shortcut.textContent = navigator.platform?.includes('Mac') ? '⌘K' : 'Ctrl+K';
  }

  // Mobile menu
  (function () {
    var menu = document.querySelector('.mobile-menu');
    var open = document.querySelector('.hamburger');
    var close = document.querySelector('.mobile-close');
    if (!menu || !open || !close) return;

    function toggle(show) {
      menu.setAttribute('aria-hidden', String(!show));
      menu.classList.toggle('is-open', show);
      document.body.style.overflow = show ? 'hidden' : '';
    }

    open.addEventListener('click', function () { toggle(true); });
    close.addEventListener('click', function () { toggle(false); });
    menu.addEventListener('click', function (e) {
      if (e.target === menu) toggle(false);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) toggle(false);
    });
  })();
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--re-nav-bg);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--re-border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    gap: var(--re-space-6);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    font-size: 1rem;
    color: var(--re-text-primary);
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: var(--re-space-6);
  }

  .nav-links a {
    color: var(--re-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover { color: var(--re-text-primary); }

  .github-link {
    display: flex;
    align-items: center;
    color: var(--re-text-secondary);
  }
  .github-link:hover { color: var(--re-text-primary); }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--re-space-3);
    flex-shrink: 0;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    font-size: 0.8125rem;
    color: var(--re-text-muted);
    border: 1px solid var(--re-border);
    border-radius: var(--re-radius-sm);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .search-trigger:hover { border-color: var(--re-brand-500); color: var(--re-brand-500); text-decoration: none; }
  .search-label { font-weight: 500; }
  .search-trigger kbd { font-family: var(--re-font-sans); font-size: 0.6875rem; padding: 1px 5px; background: var(--re-bg-soft); border-radius: 3px; color: var(--re-text-muted); }

  .locale-switch {
    padding: 4px 10px;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--re-text-muted);
    border: 1px solid var(--re-border);
    border-radius: var(--re-radius-sm);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .locale-switch:hover { border-color: var(--re-brand-500); color: var(--re-brand-500); text-decoration: none; }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid var(--re-border-strong);
    border-radius: var(--re-radius-md);
    color: var(--re-text-secondary);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .theme-toggle:hover { border-color: var(--re-brand-500); color: var(--re-brand-500); }

  :global([data-theme="dark"]) .icon-moon { display: none; }
  :global([data-theme="light"]) .icon-sun { display: none; }
  :global(:not([data-theme])) .icon-sun { display: none; }

  /* Hamburger — hidden on desktop */
  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    color: var(--re-text-primary);
    cursor: pointer;
  }

  /* Mobile menu panel */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.5);
  }

  .mobile-menu.is-open { display: flex; justify-content: flex-end; }

  .mobile-menu-inner {
    width: 280px;
    height: 100%;
    background: var(--re-bg-elevated);
    border-left: 1px solid var(--re-border);
    padding: var(--re-space-6);
    display: flex;
    flex-direction: column;
  }

  .mobile-close {
    align-self: flex-end;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    color: var(--re-text-primary);
    cursor: pointer;
    margin-bottom: var(--re-space-6);
  }

  .mobile-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--re-space-1);
  }

  .mobile-links a {
    display: block;
    padding: var(--re-space-3) var(--re-space-4);
    font-size: 1rem;
    font-weight: 500;
    color: var(--re-text-primary);
    text-decoration: none;
    border-radius: var(--re-radius-md);
    transition: background 0.15s;
  }

  .mobile-links a:hover { background: var(--re-bg-soft); }

  .mobile-footer {
    margin-top: auto;
    padding-top: var(--re-space-6);
    border-top: 1px solid var(--re-border);
  }

  /* Mobile breakpoint */
  @media (max-width: 768px) {
    .nav-desktop { display: none; }
    .hamburger { display: flex; }
    .search-label, .search-kbd { display: none; }
  }
</style>
