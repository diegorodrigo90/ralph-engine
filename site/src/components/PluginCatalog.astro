---
import PluginIcon from './PluginIcon.astro';
import type { Locale } from '../i18n/utils';
import { t, localePath } from '../i18n/utils';
import plugins from '../data/plugins.json';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const kindLabels: Record<string, string> = {
  template: t(lang, 'catalog.kind.template'),
  agent_runtime: t(lang, 'catalog.kind.agent_runtime'),
  mcp_contribution: t(lang, 'catalog.kind.mcp_contribution'),
  policy: t(lang, 'catalog.kind.policy'),
  remote_control: t(lang, 'catalog.kind.remote_control'),
};

const kinds = [...new Set(plugins.map((p: any) => p.kind))];
function countForKind(kind: string): number {
  return plugins.filter((p: any) => p.kind === kind).length;
}

function getName(p: any): string {
  if (lang !== 'en' && p.display_name_locales?.[lang]) return p.display_name_locales[lang];
  return p.display_name;
}

function getSummary(p: any): string {
  if (lang !== 'en' && p.summary_locales?.[lang]) return p.summary_locales[lang];
  return p.summary;
}

const officialLabel = lang === 'pt-br' ? 'Oficial' : 'Official';
---

<section class="section not-content">
  <div class="container">

    {/* Header */}
    <h1 class="catalog-title">{t(lang, 'catalog.title')}</h1>
    <p class="catalog-desc">{t(lang, 'catalog.description')}</p>

    {/* Terminal — visible, CLI is the product identity */}
    <div class="catalog-terminal">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-body">
          <div class="terminal-prompt">ralph-engine plugins list</div>
          <div class="terminal-output">
            <div>{lang === 'pt-br' ? 'Plugins oficiais' : 'Official plugins'} ({plugins.length})</div>
            {plugins.map((p: any) => (
              <div>- {p.id.padEnd(22)} | {(kindLabels[p.kind] ?? p.kind).padEnd(18)} | {lang === 'pt-br' ? 'ativo' : 'enabled'}</div>
            ))}
          </div>
        </div>
      </div>
    </div>

    {/* Filters */}
    <div class="filter-row">
      <div class="filter-bar" id="filter-bar">
        <button class="filter-chip filter-active" data-kind="all">{t(lang, 'catalog.all')}</button>
        {kinds.map((kind: string) => (
          <button class={`filter-chip chip-${kind}`} data-kind={kind}>
            <span class={`chip-dot dot-${kind}`}></span>
            {kindLabels[kind] ?? kind}
            <span class="chip-count">{countForKind(kind)}</span>
          </button>
        ))}
      </div>
      <span class="filter-results" id="filter-results" aria-live="polite"></span>
    </div>

    {/* Grid */}
    <div class="plugin-grid" id="plugin-grid">
      {plugins.map((plugin: any) => (
        <a
          href={localePath(lang, `/plugins/${plugin.id.replace('official.', '')}/`)}
          class={`plugin-card kind-${plugin.kind}`}
          data-kind={plugin.kind}
        >
          <div class="card-accent"></div>
          <div class="card-body">
            <div class="card-top">
              <div class={`plugin-icon kind-icon-${plugin.kind}`} aria-hidden="true">
                <PluginIcon iconUrl={plugin.iconUrl} kind={plugin.kind} size={22} />
              </div>
              <div class="card-title-area">
                <h3 class="plugin-name">{getName(plugin)}</h3>
                <code class="plugin-id">{plugin.id}</code>
              </div>
            </div>

            <p class="plugin-summary">{getSummary(plugin)}</p>

            <div class="card-footer">
              <div class="card-badges">
                {plugin.trust_level === 'official' && <span class="badge badge-official">{officialLabel}</span>}
                <span class={`badge badge-${plugin.kind}`}>{kindLabels[plugin.kind] ?? plugin.kind}</span>
                {plugin.capabilities?.length > 1 && plugin.capabilities
                  .filter((c: string) => c !== plugin.kind)
                  .map((cap: string) => <span class="badge">{cap.replace('_', ' ')}</span>)}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    {/* Empty state */}
    <p class="empty-state" id="empty-state" style="display: none;">
      {lang === 'pt-br' ? 'Nenhum plugin para este filtro.' : 'No plugins match this filter.'}
    </p>

  </div>
</section>

<script is:inline>
  (function () {
    var cards = document.querySelectorAll('.plugin-card');
    var filters = document.querySelectorAll('.filter-chip');
    var results = document.getElementById('filter-results');
    var emptyState = document.getElementById('empty-state');
    var grid = document.getElementById('plugin-grid');
    var total = cards.length;
    var activeKind = 'all';

    function applyFilter() {
      var visible = 0;
      cards.forEach(function (card) {
        var kind = card.getAttribute('data-kind');
        var show = activeKind === 'all' || kind === activeKind;
        if (show) {
          card.style.opacity = ''; card.style.transform = ''; card.style.display = '';
          visible++;
        } else {
          card.style.opacity = '0'; card.style.transform = 'scale(0.97)';
          setTimeout(function () { if (card.style.opacity === '0') card.style.display = 'none'; }, 200);
        }
      });
      if (results) results.textContent = activeKind === 'all' ? '' : visible + ' / ' + total;
      if (emptyState) emptyState.style.display = visible === 0 ? '' : 'none';
    }

    filters.forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeKind = btn.getAttribute('data-kind') || 'all';
        filters.forEach(function (b) { b.classList.toggle('filter-active', b === btn); });
        cards.forEach(function (c) { c.style.display = ''; });
        requestAnimationFrame(function () { applyFilter(); });
      });
    });
  })();
</script>

<style>
  /* ── Mobile-first ── */

  .catalog-title { margin-bottom: var(--re-space-1); }

  .catalog-desc {
    font-size: 1rem;
    color: var(--re-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--re-space-6);
  }

  /* Terminal */
  .catalog-terminal {
    margin-bottom: var(--re-space-6);
  }

  /* Filters */
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--re-space-3);
    margin-bottom: var(--re-space-5);
    padding-bottom: var(--re-space-4);
    border-bottom: 1px solid var(--re-border);
  }

  .filter-bar { display: flex; flex-wrap: wrap; gap: 6px; }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 14px;
    min-height: 36px;
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: var(--re-font-sans);
    border: 1px solid var(--re-border);
    border-radius: var(--re-radius-full);
    background: transparent;
    color: var(--re-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-chip:hover { color: var(--re-text-primary); border-color: var(--re-text-muted); }
  .filter-chip:focus-visible { outline: 2px solid var(--re-brand-500); outline-offset: 2px; }

  .filter-chip.filter-active {
    background: var(--re-bg-soft);
    border-color: var(--re-text-primary);
    color: var(--re-text-primary);
    font-weight: 700;
  }

  .chip-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .dot-template { background: var(--re-kind-template); }
  .dot-agent_runtime { background: var(--re-kind-agent); }
  .dot-mcp_contribution { background: var(--re-kind-mcp); }
  .dot-policy { background: var(--re-kind-policy); }
  .dot-remote_control { background: var(--re-kind-remote); }

  .chip-count { font-size: 0.6875rem; opacity: 0.6; }

  .filter-results {
    font-size: 0.8125rem;
    color: var(--re-text-muted);
    white-space: nowrap;
    margin-left: auto;
  }

  /* Grid — mobile first: 1 column */
  .plugin-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--re-space-3);
  }

  /* Card */
  .plugin-card {
    display: flex;
    overflow: hidden;
    border-radius: var(--re-radius-lg);
    background: var(--re-card-bg);
    border: 1px solid var(--re-border);
    text-decoration: none;
    color: var(--re-text-primary);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .plugin-card:hover {
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.07);
    border-color: var(--re-brand-400);
  }

  .plugin-card:focus-visible {
    outline: 2px solid var(--re-brand-500);
    outline-offset: 2px;
  }

  .card-accent { width: 4px; flex-shrink: 0; }
  .kind-template .card-accent { background: var(--re-kind-template); }
  .kind-agent_runtime .card-accent { background: var(--re-kind-agent); }
  .kind-mcp_contribution .card-accent { background: var(--re-kind-mcp); }
  .kind-policy .card-accent { background: var(--re-kind-policy); }
  .kind-remote_control .card-accent { background: var(--re-kind-remote); }

  .card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--re-space-2);
    padding: var(--re-space-4);
    min-width: 0;
  }

  .card-top { display: flex; align-items: flex-start; gap: var(--re-space-3); }

  .plugin-icon {
    flex-shrink: 0;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    border-radius: var(--re-radius-md);
  }

  .kind-icon-template { background: var(--re-kind-template-soft); color: var(--re-kind-template); }
  .kind-icon-agent_runtime { background: var(--re-kind-agent-soft); color: var(--re-kind-agent); }
  .kind-icon-mcp_contribution { background: var(--re-kind-mcp-soft); color: var(--re-kind-mcp); }
  .kind-icon-policy { background: var(--re-kind-policy-soft); color: var(--re-kind-policy); }
  .kind-icon-remote_control { background: var(--re-kind-remote-soft); color: var(--re-kind-remote); }

  .card-title-area { min-width: 0; }
  .plugin-name { font-size: 1rem; line-height: 1.3; }
  .plugin-id { font-family: var(--re-font-mono); font-size: 0.6875rem; color: var(--re-text-muted); display: block; margin-top: 1px; }

  .plugin-summary { font-size: 0.8125rem; color: var(--re-text-secondary); line-height: 1.5; flex: 1; }

  .card-footer {
    padding-top: var(--re-space-2);
    border-top: 1px solid var(--re-border);
  }

  .card-badges { display: flex; flex-wrap: wrap; gap: 4px; }

  .badge {
    display: inline-block;
    padding: 2px 7px;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-radius: var(--re-radius-full);
    background: var(--re-pill-bg);
    color: var(--re-pill-text);
  }

  .badge-official { background: var(--re-brand-50); color: var(--re-brand-600); }
  .badge-template { background: var(--re-kind-template-soft); color: var(--re-kind-template); }
  .badge-agent_runtime { background: var(--re-kind-agent-soft); color: var(--re-kind-agent); }
  .badge-mcp_contribution { background: var(--re-kind-mcp-soft); color: var(--re-kind-mcp); }
  .badge-policy { background: var(--re-kind-policy-soft); color: var(--re-kind-policy); }
  .badge-remote_control { background: var(--re-kind-remote-soft); color: var(--re-kind-remote); }

  .empty-state {
    text-align: center;
    padding: var(--re-space-10) 0;
    color: var(--re-text-muted);
    font-size: 0.9375rem;
  }

  /* ── Tablet: 2 columns ── */
  @media (min-width: 640px) {
    .plugin-grid { grid-template-columns: repeat(2, 1fr); gap: var(--re-space-4); }
    .catalog-terminal { max-width: 520px; }
  }

  /* ── Desktop: 3 columns, more spacing ── */
  @media (min-width: 960px) {
    .plugin-grid { grid-template-columns: repeat(3, 1fr); }
    .catalog-desc { font-size: 1.0625rem; }
  }
</style>
