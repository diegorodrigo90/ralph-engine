---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section class="section">
  <div class="container">
    <h2 class="features-heading">{lang === 'pt-br' ? 'O que o Ralph Engine faz' : 'What Ralph Engine does'}</h2>
    <div class="grid-4">
      <div class="card feature-card">
        <div class="feature-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3>{t(lang, 'features.plugins.title')}</h3>
        <p>{t(lang, 'features.plugins.description')}</p>
      </div>

      <div class="card feature-card">
        <div class="feature-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>
          </svg>
        </div>
        <h3>{t(lang, 'features.checks.title')}</h3>
        <p>{t(lang, 'features.checks.description')}</p>
      </div>

      <div class="card feature-card">
        <div class="feature-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 8V4H8"/><rect x="4" y="8" width="16" height="10" rx="2"/><circle cx="9" cy="13" r="1" fill="currentColor"/><circle cx="15" cy="13" r="1" fill="currentColor"/>
          </svg>
        </div>
        <h3>{t(lang, 'features.agents.title')}</h3>
        <p>{t(lang, 'features.agents.description')}</p>
      </div>

      <div class="card feature-card">
        <div class="feature-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8H6a2 2 0 0 0-2 2v2c0 4.418 3.582 8 8 8s8-3.582 8-8v-2a2 2 0 0 0-2-2z"/>
          </svg>
        </div>
        <h3>{t(lang, 'features.mcp.title')}</h3>
        <p>{t(lang, 'features.mcp.description')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .features-heading {
    font-size: 1.5rem;
    color: var(--re-text-primary);
    margin-bottom: var(--re-space-6);
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--re-space-3);
    cursor: default;
  }

  .feature-card:hover {
    border-color: var(--re-border);
    box-shadow: var(--re-card-shadow);
    transform: none;
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--re-brand-50);
    color: var(--re-brand-500);
    border-radius: var(--re-radius-md);
  }

  .feature-card h3 {
    font-size: 1.0625rem;
  }

  .feature-card p {
    font-size: 0.875rem;
    color: var(--re-text-secondary);
    line-height: 1.5;
  }
</style>
