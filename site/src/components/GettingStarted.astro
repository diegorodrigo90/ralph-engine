---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const steps = [
  { key: 'step1' },
  { key: 'step2' },
  { key: 'step3' },
];
---

<section class="section not-content">
  <div class="container">
    <h2 style="text-align: center; margin-bottom: 40px;">
      {t(lang, 'getting-started.title')}
    </h2>
    <div class="grid-3">
      {steps.map(({ key }, i) => {
        const cmd = t(lang, `getting-started.${key}.code`);
        return (
          <div class="card step-card">
            <span class="step-number">{i + 1}</span>
            <h3>{t(lang, `getting-started.${key}.title`)}</h3>
            <div class="cmd-block">
              <code>{cmd}</code>
              <button class="copy-btn" type="button" data-copy={cmd} aria-label="Copy">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .step-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: center;
    align-items: center;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--re-brand-500);
    color: #fff;
    font-weight: 700;
    font-size: 0.9375rem;
  }

  .step-card .cmd-block {
    width: 100%;
    text-align: left;
  }
</style>

<script is:inline>
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.copy-btn');
    if (!btn) return;
    var text = btn.getAttribute('data-copy');
    if (!text) return;
    navigator.clipboard.writeText(text).then(function () {
      btn.classList.add('copied');
      setTimeout(function () { btn.classList.remove('copied'); }, 2000);
    });
  });
</script>
