---
import Base from '../layouts/Base.astro';

const lang = 'en' as const;
---

<Base lang={lang} title="Page not found">
  <section class="section" style="text-align: center;">
    <div class="container">
      <h1 style="font-size: 4rem; color: var(--re-text-muted);">404</h1>
      <p style="font-size: 1.125rem; color: var(--re-text-secondary); margin-top: var(--re-space-4);">
        Page not found.
      </p>
      <div style="margin-top: var(--re-space-8); display: flex; gap: var(--re-space-3); justify-content: center;">
        <a href="/" class="btn btn-brand">Home</a>
        <a href="/docs/getting-started/installation" class="btn btn-secondary">Docs</a>
        <a href="/plugins/" class="btn btn-secondary">Plugins</a>
      </div>
    </div>
  </section>
</Base>
