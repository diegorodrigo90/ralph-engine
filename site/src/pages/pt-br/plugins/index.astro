---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import PluginCatalog from '../../../components/PluginCatalog.astro';
import { t } from '../../../i18n/utils';

const lang = 'pt-br' as const;
---

<StarlightPage
  frontmatter={{
    title: t(lang, 'catalog.title'),
    description: t(lang, 'catalog.description'),
    template: 'splash',
    pagefind: true,
    head: [{ tag: 'style', content: '#_top { display: none; }' }],
    tableOfContents: false,
  }}
  hasSidebar={false}
>
  <PluginCatalog lang={lang} />
</StarlightPage>
