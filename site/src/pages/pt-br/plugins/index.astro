---
import Base from '../../../layouts/Base.astro';
import PluginIcon from '../../../components/PluginIcon.astro';
import { t, localePath } from '../../../i18n/utils';
import plugins from '../../../data/plugins.json';

const lang = 'pt-br' as const;

const kindLabels: Record<string, string> = {
  template: t(lang, 'catalog.kind.template'),
  agent_runtime: t(lang, 'catalog.kind.agent_runtime'),
  mcp_contribution: t(lang, 'catalog.kind.mcp_contribution'),
  policy: t(lang, 'catalog.kind.policy'),
  remote_control: t(lang, 'catalog.kind.remote_control'),
};

const kinds = [...new Set(plugins.map((p: any) => p.kind))];

function countForKind(kind: string): number {
  return plugins.filter((p: any) => p.kind === kind).length;
}

function getName(p: any): string {
  return p.display_name_locales?.['pt-br'] ?? p.display_name;
}

function getSummary(p: any): string {
  return p.summary_locales?.['pt-br'] ?? p.summary;
}
---

<Base lang={lang} title={t(lang, 'catalog.title')}>
  <section class="section" style="padding-top: 100px;">
    <div class="container">
      <h1 style="margin-bottom: var(--re-space-2);">{t(lang, 'catalog.title')}</h1>
      <p style="font-size: 1.125rem; color: var(--re-text-secondary); max-width: 560px; line-height: 1.6;">
        {t(lang, 'catalog.description')}
      </p>

      <div class="terminal" style="margin-top: var(--re-space-8); margin-bottom: var(--re-space-10); max-width: 560px;">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-body">
          <div class="terminal-prompt">ralph-engine plugins list</div>
          <div class="terminal-output">
            <div>Plugins oficiais ({plugins.length})</div>
            {plugins.map((p: any) => (
              <div>- {p.id.padEnd(22)} | {(kindLabels[p.kind] ?? p.kind).padEnd(18)} | ativo</div>
            ))}
          </div>
        </div>
      </div>

      <div style="display: flex; flex-wrap: wrap; gap: var(--re-space-2); margin-bottom: var(--re-space-8);">
        <span class="pill pill-brand" style="font-weight: 700;">{t(lang, 'catalog.all')} ({plugins.length})</span>
        {kinds.map((kind: string) => (
          <span class="pill">{kindLabels[kind] ?? kind} ({countForKind(kind)})</span>
        ))}
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--re-space-5);">
        {plugins.map((plugin: any) => (
          <a href={localePath(lang, `/plugins/${plugin.id.replace('official.', '')}/`)} class="card" style="display: flex; flex-direction: column; gap: var(--re-space-3); text-decoration: none; color: var(--re-text-primary);">
            <div style="display: flex; align-items: flex-start; gap: var(--re-space-3);">
              <div style="flex-shrink: 0; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: var(--re-brand-50); color: var(--re-brand-500); border-radius: var(--re-radius-md);" aria-hidden="true">
                <PluginIcon pluginId={plugin.id} size={20} />
              </div>
              <div>
                <h3 style="font-size: 1.0625rem; line-height: 1.3;">{getName(plugin)}</h3>
                <span style="font-family: var(--re-font-mono); font-size: 0.75rem; color: var(--re-text-muted);">{plugin.id}</span>
              </div>
              <span class="pill pill-brand" style="margin-left: auto; flex-shrink: 0;">{kindLabels[plugin.kind] ?? plugin.kind}</span>
            </div>
            <p style="font-size: 0.875rem; color: var(--re-text-secondary); line-height: 1.5; flex: 1;">{getSummary(plugin)}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 4px;">
              {plugin.capabilities?.map((cap: string) => <span class="pill">{cap}</span>)}
            </div>
            <div style="display: flex; flex-wrap: wrap; gap: var(--re-space-3); font-size: 0.75rem; color: var(--re-text-muted); padding-top: var(--re-space-2); border-top: 1px solid var(--re-border);">
              {plugin.templates && <span>{plugin.templates.length} template{plugin.templates.length !== 1 ? 's' : ''}</span>}
              {plugin.agents && <span>{plugin.agents.length} agente{plugin.agents.length !== 1 ? 's' : ''}</span>}
              {plugin.providers && <span>{plugin.providers.length} provedor{plugin.providers.length !== 1 ? 'es' : ''}</span>}
              <span>v{plugin.plugin_version}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
