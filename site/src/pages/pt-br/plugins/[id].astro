---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import PluginDetail from '../../../components/PluginDetail.astro';
import plugins from '../../../data/plugins.json';

const lang = 'pt-br' as const;

export function getStaticPaths() {
  return plugins.map((plugin: any) => ({
    params: { id: plugin.id.replace('official.', '') },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;
const name = plugin.display_name_locales?.['pt-br'] ?? plugin.display_name;
---

<StarlightPage
  frontmatter={{
    title: `Plugin ${name}`,
    description: plugin.summary_locales?.['pt-br'] ?? plugin.summary,
    template: 'splash',
    pagefind: true,
    head: [{ tag: 'style', content: '#_top { display: none; } body { --sl-content-width: 72rem; }' }],
    tableOfContents: false,
  }}
  hasSidebar={false}
>
  <PluginDetail lang={lang} plugin={plugin} />
</StarlightPage>
