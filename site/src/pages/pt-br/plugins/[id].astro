---
import Base from '../../../layouts/Base.astro';
import PluginIcon from '../../../components/PluginIcon.astro';
import { t, localePath } from '../../../i18n/utils';
import plugins from '../../../data/plugins.json';

const lang = 'pt-br' as const;

export function getStaticPaths() {
  return plugins.map((plugin: any) => ({
    params: { id: plugin.id.replace('official.', '') },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;

function getName(p: any): string { return p.display_name_locales?.['pt-br'] ?? p.display_name; }
function getSummary(p: any): string { return p.summary_locales?.['pt-br'] ?? p.summary; }

const kindLabels: Record<string, string> = {
  template: t(lang, 'catalog.kind.template'),
  agent_runtime: t(lang, 'catalog.kind.agent_runtime'),
  mcp_contribution: t(lang, 'catalog.kind.mcp_contribution'),
  policy: t(lang, 'catalog.kind.policy'),
  remote_control: t(lang, 'catalog.kind.remote_control'),
};

function buildDescription(p: any): string {
  const parts: string[] = [];
  if (p.agents?.length) parts.push(`${p.agents.length} runtime${p.agents.length > 1 ? 's' : ''} de agente`);
  if (p.templates?.length) parts.push(`${p.templates.length} template${p.templates.length > 1 ? 's' : ''} starter`);
  if (p.providers?.length) parts.push(`${p.providers.length} provedor${p.providers.length > 1 ? 'es' : ''}`);
  if (p.checks?.length) parts.push(`${p.checks.length} check${p.checks.length > 1 ? 's' : ''} de runtime`);
  if (p.policies?.length) parts.push(`${p.policies.length} política${p.policies.length > 1 ? 's' : ''}`);
  return parts.length ? `Inclui ${parts.join(', ')}.` : '';
}

const allTags = [plugin.kind, plugin.trust_level, ...(plugin.capabilities ?? [])].filter(Boolean);
---

<Base lang={lang} title={`Plugin ${getName(plugin)}`}>
  <section class="section" style="padding-top: 80px;">
    <div class="container" style="max-width: 800px;">

      <a href={localePath(lang, '/plugins/')} class="back-link">← {t(lang, 'plugin.back')}</a>

      <div class="detail-header">
        <div class="detail-icon" aria-hidden="true">
          <PluginIcon iconUrl={plugin.iconUrl} kind={plugin.kind} size={28} />
        </div>
        <div>
          <h1 class="detail-title">{getName(plugin)}</h1>
          <div class="detail-meta">
            <code>{plugin.id}</code>
            <span class="pill pill-brand">{kindLabels[plugin.kind] ?? plugin.kind}</span>
          </div>
        </div>
      </div>

      <p class="detail-summary">{getSummary(plugin)}</p>
      {buildDescription(plugin) && <p class="detail-ships">{buildDescription(plugin)}</p>}

      <div class="detail-tags">
        {allTags.map((tag: string) => <span class="pill">{tag}</span>)}
        <span class="pill">v{plugin.plugin_version}</span>
      </div>

      {/* Install — prominent */}
      <div class="install-hero">
        <h2>{t(lang, 'plugin.install')}</h2>
        <div class="install-grid">
          <div class="install-option">
            <span class="install-label">Cargo</span>
            <div class="code-block install-cmd">
              <code>cargo install ralph-engine</code>
              <button class="copy-btn" type="button" data-copy="cargo install ralph-engine" aria-label="Copiar">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>
          <div class="install-option">
            <span class="install-label">npm</span>
            <div class="code-block install-cmd">
              <code>npm install -g ralph-engine</code>
              <button class="copy-btn" type="button" data-copy="npm install -g ralph-engine" aria-label="Copiar">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>
          <div class="install-option">
            <span class="install-label">Homebrew</span>
            <div class="code-block install-cmd">
              <code>brew install ralph-engine</code>
              <button class="copy-btn" type="button" data-copy="brew install ralph-engine" aria-label="Copiar">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>
        </div>
        <p class="install-note">
          Também disponível via <code>pnpm add -g ralph-engine</code> ou <code>yarn global add ralph-engine</code>.
          Todos os 8 plugins oficiais vêm incluídos.
        </p>
      </div>

      {/* Sub-resources */}
      {plugin.agents?.length > 0 && (
        <div>
          <h2 class="section-heading">Runtimes de Agente</h2>
          <div class="resource-list">
            {plugin.agents.map((agent: any) => (
              <div class="card resource-card">
                <h3>{agent.display_name_locales?.['pt-br'] ?? agent.display_name}</h3>
                <p>{agent.summary_locales?.['pt-br'] ?? agent.summary}</p>
                <code class="resource-id">{agent.id}</code>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.templates?.length > 0 && (
        <div>
          <h2 class="section-heading">Templates</h2>
          <div class="resource-list">
            {plugin.templates.map((tpl: any) => (
              <div class="card resource-card">
                <h3>{tpl.display_name_locales?.['pt-br'] ?? tpl.display_name}</h3>
                <p>{tpl.summary_locales?.['pt-br'] ?? tpl.summary}</p>
                <code class="resource-id">{tpl.id}</code>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.providers?.length > 0 && (
        <div>
          <h2 class="section-heading">Provedores</h2>
          <div class="resource-list">
            {plugin.providers.map((prov: any) => (
              <div class="card resource-card">
                <h3>{prov.display_name_locales?.['pt-br'] ?? prov.display_name}</h3>
                <p>{prov.summary_locales?.['pt-br'] ?? prov.summary}</p>
                <code class="resource-id">{prov.id}</code>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Technical details — collapsed */}
      <details class="details-block">
        <summary class="details-summary">Saída da CLI</summary>
        <div class="terminal">
          <div class="terminal-bar"><span class="terminal-dot"></span><span class="terminal-dot"></span><span class="terminal-dot"></span></div>
          <div class="terminal-body">
            <div class="terminal-prompt">ralph-engine plugins show {plugin.id}</div>
            <div class="terminal-output">
              <div>Plugin: {plugin.id}</div>
              <div>Nome: {getName(plugin)}</div>
              <div>Tipo: {plugin.kind}</div>
              <div>Versão: {plugin.plugin_version}</div>
              <div>Capacidades: {plugin.capabilities?.join(', ')}</div>
              <div>Runtime: {plugin.runtime ? 'sim' : 'não'}</div>
            </div>
          </div>
        </div>
      </details>

      <details class="details-block">
        <summary class="details-summary">manifest.yaml</summary>
        <div class="terminal">
          <div class="terminal-bar"><span class="terminal-dot"></span><span class="terminal-dot"></span><span class="terminal-dot"></span></div>
          <div class="terminal-body">
            <div class="terminal-prompt">cat plugins/official/{plugin.id.replace('official.', '')}/manifest.yaml</div>
            <div class="terminal-output">
              <div>id: {plugin.id}</div>
              <div>kind: {plugin.kind}</div>
              <div>display_name: {plugin.display_name}</div>
              <div>summary: {plugin.summary}</div>
              <div>publisher: {plugin.publisher}</div>
              <div>trust_level: {plugin.trust_level}</div>
              <div>plugin_version: {plugin.plugin_version}</div>
              <div>runtime: {String(plugin.runtime)}</div>
              <div>capabilities:</div>
              {plugin.capabilities?.map((c: string) => <div>  - {c}</div>)}
            </div>
          </div>
        </div>
      </details>

      <div class="detail-actions">
        <a href={`https://github.com/diegorodrigo90/ralph-engine/tree/main/plugins/official/${plugin.id.replace('official.', '')}`} target="_blank" rel="noopener" class="btn btn-secondary">
          {t(lang, 'plugin.source')} →
        </a>
        <a href={localePath(lang, '/plugins/')} class="btn btn-secondary">Todos os plugins</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .back-link { font-size: 0.875rem; color: var(--re-text-muted); display: inline-block; margin-bottom: var(--re-space-6); }
  .back-link:hover { color: var(--re-brand-500); text-decoration: none; }
  .detail-header { display: flex; align-items: flex-start; gap: var(--re-space-4); margin-bottom: var(--re-space-4); }
  .detail-icon { flex-shrink: 0; width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; background: var(--re-brand-50); color: var(--re-brand-500); border-radius: var(--re-radius-lg); }
  .detail-title { font-size: 2.25rem; line-height: 1.1; }
  .detail-meta { display: flex; align-items: center; gap: var(--re-space-2); margin-top: var(--re-space-1); }
  .detail-meta code { font-size: 0.8125rem; color: var(--re-text-muted); }
  .detail-summary { font-size: 1.125rem; color: var(--re-text-secondary); line-height: 1.6; max-width: 600px; }
  .detail-ships { font-size: 0.9375rem; color: var(--re-text-muted); margin-top: var(--re-space-2); }
  .detail-tags { display: flex; flex-wrap: wrap; gap: var(--re-space-2); margin-top: var(--re-space-4); }

  .install-hero { margin-top: var(--re-space-10); padding: var(--re-space-6); background: var(--re-bg-soft); border: 1px solid var(--re-border); border-radius: var(--re-radius-lg); }
  .install-hero h2 { font-size: 1.25rem; margin-bottom: var(--re-space-4); }
  .install-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--re-space-3); }
  .install-option { display: flex; flex-direction: column; gap: var(--re-space-1); }
  .install-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--re-text-muted); }
  .install-cmd { display: flex; align-items: center; justify-content: space-between; gap: var(--re-space-2); font-size: 0.8125rem; }
  .install-note { margin-top: var(--re-space-3); font-size: 0.8125rem; color: var(--re-text-muted); }
  .copy-btn { flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: transparent; border: none; color: var(--re-text-muted); cursor: pointer; border-radius: var(--re-radius-sm); }
  .copy-btn:hover { color: var(--re-brand-500); }

  .section-heading { font-size: 1.25rem; margin-top: var(--re-space-10); margin-bottom: var(--re-space-4); }
  .resource-list { display: flex; flex-direction: column; gap: var(--re-space-3); }
  .resource-card { display: flex; flex-direction: column; gap: var(--re-space-2); }
  .resource-card h3 { font-size: 1rem; }
  .resource-card p { font-size: 0.875rem; color: var(--re-text-secondary); line-height: 1.5; }
  .resource-id { font-size: 0.75rem; color: var(--re-text-muted); }

  .details-block { margin-top: var(--re-space-8); border: 1px solid var(--re-border); border-radius: var(--re-radius-lg); overflow: hidden; }
  .details-summary { padding: var(--re-space-4) var(--re-space-6); font-weight: 600; font-size: 1rem; cursor: pointer; color: var(--re-text-secondary); background: var(--re-bg-soft); list-style: none; display: flex; align-items: center; gap: var(--re-space-2); }
  .details-summary::-webkit-details-marker { display: none; }
  .details-summary::before { content: '▶'; font-size: 0.625rem; transition: transform 0.15s; }
  details[open] .details-summary::before { transform: rotate(90deg); }
  .details-block[open] .details-summary { border-bottom: 1px solid var(--re-border); }
  .details-block .terminal { border-radius: 0; border: none; box-shadow: none; }

  .detail-actions { margin-top: var(--re-space-10); display: flex; flex-wrap: wrap; gap: var(--re-space-3); }

  @media (max-width: 640px) { .install-grid { grid-template-columns: 1fr; } }
</style>
