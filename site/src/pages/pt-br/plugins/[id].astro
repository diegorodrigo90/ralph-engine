---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import PluginDetail from '../../../components/PluginDetail.astro';
import plugins from '../../../data/plugins.json';

const lang = 'pt-br' as const;

export function getStaticPaths() {
  return plugins.map((plugin: any) => ({
    params: { id: plugin.id.replace('official.', '') },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;

function getName(p: any): string {
  return p.display_name_locales?.['pt-br'] ?? p.display_name;
}
---

<StarlightPage
  frontmatter={{
    title: `Plugin ${getName(plugin)}`,
    description: plugin.summary_locales?.['pt-br'] ?? plugin.summary,
    template: 'splash',
    pagefind: true,
    head: [],
    tableOfContents: false,
  }}
  hasSidebar={false}
>
  <PluginDetail lang={lang} plugin={plugin} />
</StarlightPage>
