---
import Base from '../../layouts/Base.astro';
import { t, localePath } from '../../i18n/utils';
import plugins from '../../data/plugins.json';

const lang = 'en' as const;

export function getStaticPaths() {
  return plugins.map((plugin: any) => ({
    params: { id: plugin.id.replace('official.', '') },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;

const kindLabels: Record<string, string> = {
  template: 'Template',
  agent_runtime: 'Agent Runtime',
  mcp_contribution: 'MCP Contribution',
  policy: 'Policy',
  remote_control: 'Remote Control',
};

const kindIcons: Record<string, string> = {
  template: 'M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5 M2 12l10 5 10-5',
  agent_runtime: 'M12 8V4H8 M4 8h16a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2v-6a2 2 0 012-2z M9 13h0 M15 13h0',
  mcp_contribution: 'M12 22v-5 M9 8V2 M15 8V2 M18 8H6a2 2 0 00-2 2v2c0 4.418 3.582 8 8 8s8-3.582 8-8v-2a2 2 0 00-2-2z',
  policy: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9 12l2 2 4-4',
  remote_control: 'M4 17l6-6 M7 7l4.586 4.586a2 2 0 010 2.828L7 19 M20 7l-4.586 4.586a2 2 0 000 2.828L20 19',
};
---

<Base lang={lang} title={`${plugin.display_name} plugin`}>
  <section class="section" style="padding-top: 80px;">
    <div class="container detail-layout">

      <a href={localePath(lang, '/plugins/')} class="back-link">
        ← {t(lang, 'plugin.back')}
      </a>

      <div class="detail-header">
        <div class="detail-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d={kindIcons[plugin.kind] ?? kindIcons.template} />
          </svg>
        </div>
        <div>
          <h1 class="detail-title">{plugin.display_name}</h1>
          <div class="detail-meta">
            <code>{plugin.id}</code>
            <span class="pill pill-brand">{kindLabels[plugin.kind] ?? plugin.kind}</span>
            <span class="pill pill-brand">official</span>
          </div>
        </div>
      </div>

      <p class="detail-summary">{plugin.summary}</p>

      {/* Terminal: real CLI output */}
      <div class="terminal" style="margin: var(--re-space-8) 0;">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-body">
          <div class="terminal-prompt">ralph-engine plugins show {plugin.id}</div>
          <div class="terminal-output">
            <div>Plugin: {plugin.id}</div>
            <div>Name: {plugin.display_name}</div>
            <div>Kind: {plugin.kind}</div>
            <div>Version: {plugin.plugin_version}</div>
            <div>Trust: {plugin.trust_level}</div>
            <div>Capabilities: {plugin.capabilities?.join(', ')}</div>
            <div>Runtime: {plugin.runtime ? 'yes' : 'no'}</div>
            {plugin.agents && <div>Agents: {plugin.agents.length} registered</div>}
            {plugin.templates && <div>Templates: {plugin.templates.length} registered</div>}
            {plugin.providers && <div>Providers: {plugin.providers.length} registered</div>}
            {plugin.checks && <div>Checks: {plugin.checks.length} registered</div>}
            {plugin.policies && <div>Policies: {plugin.policies.length} registered</div>}
          </div>
        </div>
      </div>

      {/* Install options */}
      <h2 class="section-heading">Install</h2>
      <div class="install-tabs">
        <div class="tabs">
          <input type="radio" name="install-tab" id="install-cargo" checked />
          <input type="radio" name="install-tab" id="install-npm" />
          <input type="radio" name="install-tab" id="install-brew" />

          <div class="tab-list" role="tablist">
            <label for="install-cargo" role="tab">Cargo</label>
            <label for="install-npm" role="tab">npm</label>
            <label for="install-brew" role="tab">Homebrew</label>
          </div>

          <div class="tab-panel">
            <div class="code-block">
              <code>cargo install ralph-engine</code>
            </div>
          </div>
          <div class="tab-panel">
            <div class="code-block">
              <code>npx ralph-engine plugins show {plugin.id}</code>
            </div>
          </div>
          <div class="tab-panel">
            <div class="code-block">
              <code>brew install ralph-engine</code>
            </div>
          </div>
        </div>
      </div>

      {/* Capabilities */}
      <h2 class="section-heading">Capabilities</h2>
      <div class="caps-grid">
        {plugin.capabilities?.map((cap: string) => (
          <div class="card cap-card">
            <span class="pill pill-brand">{cap}</span>
          </div>
        ))}
      </div>

      {/* Sub-resources */}
      {plugin.agents?.length > 0 && (
        <div>
          <h2 class="section-heading">Agent Runtimes</h2>
          <div class="resource-list">
            {plugin.agents.map((agent: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{agent.display_name}</h3>
                  <code>{agent.id}</code>
                </div>
                <p>{agent.summary}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.templates?.length > 0 && (
        <div>
          <h2 class="section-heading">Templates</h2>
          <div class="resource-list">
            {plugin.templates.map((tpl: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{tpl.display_name}</h3>
                  <code>{tpl.id}</code>
                </div>
                <p>{tpl.summary}</p>
                <div class="terminal" style="margin-top: var(--re-space-3);">
                  <div class="terminal-bar">
                    <span class="terminal-dot"></span>
                    <span class="terminal-dot"></span>
                    <span class="terminal-dot"></span>
                  </div>
                  <div class="terminal-body">
                    <div class="terminal-prompt">ralph-engine templates materialize {tpl.id} ./my-project</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.providers?.length > 0 && (
        <div>
          <h2 class="section-heading">Providers</h2>
          <div class="resource-list">
            {plugin.providers.map((prov: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{prov.display_name}</h3>
                  <code>{prov.id}</code>
                </div>
                <p>{prov.summary}</p>
                <span class="pill" style="margin-top: var(--re-space-2);">{prov.kind}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.checks?.length > 0 && (
        <div>
          <h2 class="section-heading">Checks</h2>
          <div class="resource-list">
            {plugin.checks.map((check: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{check.display_name}</h3>
                  <code>{check.id}</code>
                </div>
                <p>{check.summary}</p>
                <span class="pill" style="margin-top: var(--re-space-2);">{check.kind}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.policies?.length > 0 && (
        <div>
          <h2 class="section-heading">Policies</h2>
          <div class="resource-list">
            {plugin.policies.map((pol: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{pol.display_name}</h3>
                  <code>{pol.id}</code>
                </div>
                <p>{pol.summary}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Manifest */}
      <h2 class="section-heading">manifest.yaml</h2>
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-body">
          <div class="terminal-prompt">cat plugins/official/{plugin.id.replace('official.', '')}/manifest.yaml</div>
          <div class="terminal-output">
            <div>id: {plugin.id}</div>
            <div>kind: {plugin.kind}</div>
            <div>display_name: {plugin.display_name}</div>
            <div>summary: {plugin.summary}</div>
            <div>publisher: {plugin.publisher}</div>
            <div>trust_level: {plugin.trust_level}</div>
            <div>plugin_version: {plugin.plugin_version}</div>
            <div>plugin_api_version: {plugin.plugin_api_version}</div>
            <div>runtime: {String(plugin.runtime)}</div>
            <div>capabilities:</div>
            {plugin.capabilities?.map((c: string) => <div>  - {c}</div>)}
          </div>
        </div>
      </div>

      {/* Source link */}
      <div style="margin-top: var(--re-space-8); display: flex; gap: var(--re-space-3);">
        <a
          href={`https://github.com/diegorodrigo90/ralph-engine/tree/main/plugins/official/${plugin.id.replace('official.', '')}`}
          target="_blank"
          rel="noopener"
          class="btn btn-secondary"
        >
          View source →
        </a>
        <a href={localePath(lang, '/plugins/')} class="btn btn-secondary">
          All plugins
        </a>
      </div>

    </div>
  </section>
</Base>

<style>
  .detail-layout {
    max-width: 800px;
  }

  .back-link {
    font-size: 0.875rem;
    color: var(--re-text-muted);
    display: inline-block;
    margin-bottom: var(--re-space-6);
  }

  .back-link:hover {
    color: var(--re-brand-500);
  }

  .detail-header {
    display: flex;
    align-items: flex-start;
    gap: var(--re-space-4);
    margin-bottom: var(--re-space-4);
  }

  .detail-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--re-brand-50);
    color: var(--re-brand-500);
    border-radius: var(--re-radius-lg);
  }

  .detail-title {
    font-size: 2.25rem;
    line-height: 1.1;
  }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: var(--re-space-2);
    margin-top: var(--re-space-1);
  }

  .detail-meta code {
    font-size: 0.8125rem;
    color: var(--re-text-muted);
  }

  .detail-summary {
    font-size: 1.125rem;
    color: var(--re-text-secondary);
    line-height: 1.6;
    max-width: 600px;
  }

  .section-heading {
    font-size: 1.25rem;
    margin-top: var(--re-space-10);
    margin-bottom: var(--re-space-4);
  }

  .caps-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--re-space-2);
  }

  .cap-card {
    padding: var(--re-space-3) var(--re-space-4);
  }

  .resource-list {
    display: flex;
    flex-direction: column;
    gap: var(--re-space-3);
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    gap: var(--re-space-2);
  }

  .resource-header {
    display: flex;
    align-items: baseline;
    gap: var(--re-space-3);
  }

  .resource-header h3 {
    font-size: 1rem;
  }

  .resource-header code {
    font-size: 0.75rem;
    color: var(--re-text-muted);
  }

  .resource-card p {
    font-size: 0.875rem;
    color: var(--re-text-secondary);
    line-height: 1.5;
  }

  .install-tabs {
    margin-bottom: var(--re-space-4);
  }
</style>
