---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import PluginDetail from '../../components/PluginDetail.astro';
import catalog from '../../data/plugins.json';
const plugins = catalog.plugins;

const lang = 'en' as const;

export function getStaticPaths() {
  return plugins.map((plugin: any) => ({
    params: { id: plugin.id.replace('official.', '') },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;
---

<StarlightPage
  frontmatter={{
    title: `${plugin.display_name} — Plugin`,
    description: plugin.summary,
    template: 'splash',
    pagefind: true,
    head: [{ tag: 'style', content: '#_top { display: none; } body { --sl-content-width: 72rem; }' }],
    tableOfContents: false,
  }}
  hasSidebar={false}
>
  <PluginDetail lang={lang} plugin={plugin} />
</StarlightPage>
