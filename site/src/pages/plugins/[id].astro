---
import Base from '../../layouts/Base.astro';
import PluginIcon from '../../components/PluginIcon.astro';
import { t, localePath } from '../../i18n/utils';
import plugins from '../../data/plugins.json';

const lang = 'en' as const;

export function getStaticPaths() {
  return plugins.map((plugin: any) => ({
    params: { id: plugin.id.replace('official.', '') },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;

const kindLabels: Record<string, string> = {
  template: 'Template',
  agent_runtime: 'Agent Runtime',
  mcp_contribution: 'MCP Contribution',
  policy: 'Policy',
  remote_control: 'Remote Control',
};

/** Build a richer description based on what the plugin provides. */
function buildDescription(p: any): string {
  const parts: string[] = [];
  if (p.agents?.length) parts.push(`${p.agents.length} agent runtime${p.agents.length > 1 ? 's' : ''}`);
  if (p.templates?.length) parts.push(`${p.templates.length} starter template${p.templates.length > 1 ? 's' : ''}`);
  if (p.providers?.length) parts.push(`${p.providers.length} data provider${p.providers.length > 1 ? 's' : ''}`);
  if (p.checks?.length) parts.push(`${p.checks.length} runtime check${p.checks.length > 1 ? 's' : ''}`);
  if (p.policies?.length) parts.push(`${p.policies.length} enforcement polic${p.policies.length > 1 ? 'ies' : 'y'}`);
  if (p.prompts?.length) parts.push(`${p.prompts.length} prompt bundle${p.prompts.length > 1 ? 's' : ''}`);
  return parts.length ? `Ships with ${parts.join(', ')}.` : '';
}

const allTags = [
  plugin.kind,
  plugin.trust_level,
  ...(plugin.capabilities ?? []),
].filter(Boolean);
---

<Base lang={lang} title={`${plugin.display_name} — Plugin`}>
  <section class="section" style="padding-top: 80px;">
    <div class="container detail-layout">

      <a href={localePath(lang, '/plugins/')} class="back-link">← {t(lang, 'plugin.back')}</a>

      {/* Header */}
      <div class="detail-header">
        <div class="detail-icon" aria-hidden="true">
          <PluginIcon iconUrl={plugin.iconUrl} kind={plugin.kind} size={28} />
        </div>
        <div>
          <h1 class="detail-title">{plugin.display_name}</h1>
          <div class="detail-meta">
            <code>{plugin.id}</code>
            <span class="pill pill-brand">{kindLabels[plugin.kind] ?? plugin.kind}</span>
          </div>
        </div>
      </div>

      {/* Summary + what it ships */}
      <p class="detail-summary">{plugin.summary}</p>
      {buildDescription(plugin) && (
        <p class="detail-ships">{buildDescription(plugin)}</p>
      )}

      {/* Tags */}
      <div class="detail-tags">
        {allTags.map((tag: string) => (
          <span class="pill">{tag}</span>
        ))}
        <span class="pill">v{plugin.plugin_version}</span>
        <span class="pill">API {plugin.plugin_api_version}</span>
      </div>

      {/* INSTALL — prominent, first thing after header */}
      <div class="install-hero">
        <h2>Install</h2>
        <div class="install-grid">
          <div class="install-option">
            <span class="install-label">Cargo</span>
            <div class="code-block install-cmd">
              <code>cargo install ralph-engine</code>
              <button class="copy-btn" type="button" data-copy="cargo install ralph-engine" aria-label="Copy">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>
          <div class="install-option">
            <span class="install-label">npm</span>
            <div class="code-block install-cmd">
              <code>npm install -g ralph-engine</code>
              <button class="copy-btn" type="button" data-copy="npm install -g ralph-engine" aria-label="Copy">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>
          <div class="install-option">
            <span class="install-label">Homebrew</span>
            <div class="code-block install-cmd">
              <code>brew install ralph-engine</code>
              <button class="copy-btn" type="button" data-copy="brew install ralph-engine" aria-label="Copy">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              </button>
            </div>
          </div>
        </div>
        <p class="install-note">
          Also available via <code>pnpm add -g ralph-engine</code> or <code>yarn global add ralph-engine</code>.
          All 8 official plugins are bundled — no separate install needed.
        </p>
      </div>

      {/* Technical details — collapsed by default */}
      <details class="details-block">
        <summary class="details-summary">CLI output</summary>
      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-body">
          <div class="terminal-prompt">ralph-engine plugins show {plugin.id}</div>
          <div class="terminal-output">
            <div>Plugin: {plugin.id}</div>
            <div>Name: {plugin.display_name}</div>
            <div>Kind: {plugin.kind}</div>
            <div>Version: {plugin.plugin_version}</div>
            <div>Trust: {plugin.trust_level}</div>
            <div>Capabilities: {plugin.capabilities?.join(', ')}</div>
            <div>Runtime: {plugin.runtime ? 'yes' : 'no'}</div>
            {plugin.agents && <div>Agents: {plugin.agents.length} registered</div>}
            {plugin.templates && <div>Templates: {plugin.templates.length} registered</div>}
            {plugin.providers && <div>Providers: {plugin.providers.length} registered</div>}
            {plugin.checks && <div>Checks: {plugin.checks.length} registered</div>}
            {plugin.policies && <div>Policies: {plugin.policies.length} registered</div>}
          </div>
        </div>
      </div>
      </details>

      {/* Sub-resources */}
      {plugin.agents?.length > 0 && (
        <div>
          <h2 class="section-heading">Agent Runtimes</h2>
          <div class="resource-list">
            {plugin.agents.map((agent: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{agent.display_name}</h3>
                  <code>{agent.id}</code>
                </div>
                <p>{agent.summary}</p>
                <div class="terminal" style="margin-top: var(--re-space-3);">
                  <div class="terminal-bar"><span class="terminal-dot"></span><span class="terminal-dot"></span><span class="terminal-dot"></span></div>
                  <div class="terminal-body">
                    <div class="terminal-prompt">ralph-engine agents launch {agent.id}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.templates?.length > 0 && (
        <div>
          <h2 class="section-heading">Templates</h2>
          <div class="resource-list">
            {plugin.templates.map((tpl: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{tpl.display_name}</h3>
                  <code>{tpl.id}</code>
                </div>
                <p>{tpl.summary}</p>
                <div class="terminal" style="margin-top: var(--re-space-3);">
                  <div class="terminal-bar"><span class="terminal-dot"></span><span class="terminal-dot"></span><span class="terminal-dot"></span></div>
                  <div class="terminal-body">
                    <div class="terminal-prompt">ralph-engine templates materialize {tpl.id} ./my-project</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.providers?.length > 0 && (
        <div>
          <h2 class="section-heading">Providers</h2>
          <div class="resource-list">
            {plugin.providers.map((prov: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{prov.display_name}</h3>
                  <code>{prov.id}</code>
                </div>
                <p>{prov.summary}</p>
                <span class="pill" style="margin-top: var(--re-space-2); align-self: flex-start;">{prov.kind}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.checks?.length > 0 && (
        <div>
          <h2 class="section-heading">Checks</h2>
          <div class="resource-list">
            {plugin.checks.map((check: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{check.display_name}</h3>
                  <code>{check.id}</code>
                </div>
                <p>{check.summary}</p>
                <div class="terminal" style="margin-top: var(--re-space-3);">
                  <div class="terminal-bar"><span class="terminal-dot"></span><span class="terminal-dot"></span><span class="terminal-dot"></span></div>
                  <div class="terminal-body">
                    <div class="terminal-prompt">ralph-engine checks run {check.id}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {plugin.policies?.length > 0 && (
        <div>
          <h2 class="section-heading">Policies</h2>
          <div class="resource-list">
            {plugin.policies.map((pol: any) => (
              <div class="card resource-card">
                <div class="resource-header">
                  <h3>{pol.display_name}</h3>
                  <code>{pol.id}</code>
                </div>
                <p>{pol.summary}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Manifest — collapsed */}
      <details class="details-block">
        <summary class="details-summary">manifest.yaml</summary>
      <div class="terminal">
        <div class="terminal-bar"><span class="terminal-dot"></span><span class="terminal-dot"></span><span class="terminal-dot"></span></div>
        <div class="terminal-body">
          <div class="terminal-prompt">cat plugins/official/{plugin.id.replace('official.', '')}/manifest.yaml</div>
          <div class="terminal-output">
            <div>id: {plugin.id}</div>
            <div>kind: {plugin.kind}</div>
            <div>display_name: {plugin.display_name}</div>
            <div>summary: {plugin.summary}</div>
            <div>publisher: {plugin.publisher}</div>
            <div>trust_level: {plugin.trust_level}</div>
            <div>plugin_version: {plugin.plugin_version}</div>
            <div>plugin_api_version: {plugin.plugin_api_version}</div>
            <div>runtime: {String(plugin.runtime)}</div>
            <div>capabilities:</div>
            {plugin.capabilities?.map((c: string) => <div>  - {c}</div>)}
          </div>
        </div>
      </div>

      </details>

      {/* Actions */}
      <div class="detail-actions">
        <a
          href={`https://github.com/diegorodrigo90/ralph-engine/tree/main/plugins/official/${plugin.id.replace('official.', '')}`}
          target="_blank" rel="noopener" class="btn btn-secondary"
        >View source →</a>
        <a href="/docs/" class="btn btn-secondary">Documentation</a>
        <a href={localePath(lang, '/plugins/')} class="btn btn-secondary">All plugins</a>
      </div>

    </div>
  </section>
  </Base>

<style>
  .detail-layout { max-width: 800px; }

  .back-link {
    font-size: 0.875rem;
    color: var(--re-text-muted);
    display: inline-block;
    margin-bottom: var(--re-space-6);
  }
  .back-link:hover { color: var(--re-brand-500); text-decoration: none; }

  .detail-header {
    display: flex;
    align-items: flex-start;
    gap: var(--re-space-4);
    margin-bottom: var(--re-space-4);
  }

  .detail-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--re-brand-50);
    color: var(--re-brand-500);
    border-radius: var(--re-radius-lg);
  }

  .detail-title { font-size: 2.25rem; line-height: 1.1; }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: var(--re-space-2);
    margin-top: var(--re-space-1);
  }
  .detail-meta code { font-size: 0.8125rem; color: var(--re-text-muted); }

  .detail-summary {
    font-size: 1.125rem;
    color: var(--re-text-secondary);
    line-height: 1.6;
    max-width: 600px;
  }

  .detail-ships {
    font-size: 0.9375rem;
    color: var(--re-text-muted);
    margin-top: var(--re-space-2);
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--re-space-2);
    margin-top: var(--re-space-4);
  }

  /* Install hero — prominent */
  .install-hero {
    margin-top: var(--re-space-10);
    padding: var(--re-space-6);
    background: var(--re-bg-soft);
    border: 1px solid var(--re-border);
    border-radius: var(--re-radius-lg);
  }

  .install-hero h2 {
    font-size: 1.25rem;
    margin-bottom: var(--re-space-4);
  }

  .install-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--re-space-3);
  }

  .install-option {
    display: flex;
    flex-direction: column;
    gap: var(--re-space-1);
  }

  .install-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--re-text-muted);
  }

  .install-cmd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--re-space-2);
    font-size: 0.8125rem;
  }

  .install-note {
    margin-top: var(--re-space-3);
    font-size: 0.8125rem;
    color: var(--re-text-muted);
  }

  .copy-btn {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: none;
    color: var(--re-text-muted);
    cursor: pointer;
    border-radius: var(--re-radius-sm);
    transition: color 0.15s;
  }
  .copy-btn:hover { color: var(--re-brand-500); }
  .copy-btn.copied { color: var(--re-success, #16a34a); }

  .copy-feedback {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
  }

  .section-heading {
    font-size: 1.25rem;
    margin-top: var(--re-space-10);
    margin-bottom: var(--re-space-4);
  }

  .resource-list {
    display: flex;
    flex-direction: column;
    gap: var(--re-space-3);
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    gap: var(--re-space-2);
  }

  .resource-header {
    display: flex;
    align-items: baseline;
    gap: var(--re-space-3);
  }
  .resource-header h3 { font-size: 1rem; }
  .resource-header code { font-size: 0.75rem; color: var(--re-text-muted); }

  .resource-card p {
    font-size: 0.875rem;
    color: var(--re-text-secondary);
    line-height: 1.5;
  }

  .detail-actions {
    margin-top: var(--re-space-10);
    display: flex;
    flex-wrap: wrap;
    gap: var(--re-space-3);
  }

  /* Collapsible sections */
  .details-block {
    margin-top: var(--re-space-8);
    border: 1px solid var(--re-border);
    border-radius: var(--re-radius-lg);
    overflow: hidden;
  }

  .details-summary {
    padding: var(--re-space-4) var(--re-space-6);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    color: var(--re-text-secondary);
    background: var(--re-bg-soft);
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--re-space-2);
  }

  .details-summary::-webkit-details-marker { display: none; }

  .details-summary::before {
    content: '▶';
    font-size: 0.625rem;
    transition: transform 0.15s;
  }

  details[open] .details-summary::before {
    transform: rotate(90deg);
  }

  .details-block[open] .details-summary {
    border-bottom: 1px solid var(--re-border);
  }

  .details-block .terminal {
    border-radius: 0;
    border: none;
    box-shadow: none;
  }

  @media (max-width: 640px) {
    .install-grid { grid-template-columns: 1fr; }
  }
</style>
