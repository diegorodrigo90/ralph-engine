---
import Base from '../../layouts/Base.astro';
import PluginIcon from '../../components/PluginIcon.astro';
import { t, localePath } from '../../i18n/utils';
import plugins from '../../data/plugins.json';

const lang = 'en' as const;

const kindLabels: Record<string, string> = {
  template: t(lang, 'catalog.kind.template'),
  agent_runtime: t(lang, 'catalog.kind.agent_runtime'),
  mcp_contribution: t(lang, 'catalog.kind.mcp_contribution'),
  policy: t(lang, 'catalog.kind.policy'),
  remote_control: t(lang, 'catalog.kind.remote_control'),
};

const kinds = [...new Set(plugins.map((p: any) => p.kind))];

function countForKind(kind: string): number {
  return plugins.filter((p: any) => p.kind === kind).length;
}
---

<Base lang={lang} title={t(lang, 'catalog.title')}>
  <section class="section" style="padding-top: 100px;">
    <div class="container">
      <h1 style="margin-bottom: var(--re-space-2);">{t(lang, 'catalog.title')}</h1>
      <p class="catalog-desc">{t(lang, 'catalog.description')}</p>

      <div class="terminal" style="margin-top: var(--re-space-8); margin-bottom: var(--re-space-10); max-width: 560px;">
        <div class="terminal-bar">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
        </div>
        <div class="terminal-body">
          <div class="terminal-prompt">ralph-engine plugins list</div>
          <div class="terminal-output">
            <div>Official plugins ({plugins.length})</div>
            {plugins.map((p: any) => (
              <div>- {p.id.padEnd(22)} | {(kindLabels[p.kind] ?? p.kind).padEnd(14)} | enabled</div>
            ))}
          </div>
        </div>
      </div>

      {/* Kind filters only — global search (Pagefind) handles text search */}
      <div class="filter-bar" id="filter-bar">
        <button class="pill pill-brand filter-btn filter-active" data-kind="all">{t(lang, 'catalog.all')} ({plugins.length})</button>
        {kinds.map((kind: string) => (
          <button class="pill filter-btn" data-kind={kind}>{kindLabels[kind] ?? kind} ({countForKind(kind)})</button>
        ))}
      </div>

      <div class="results-count" id="results-count" aria-live="polite"></div>

      <div class="plugin-grid">
        {plugins.map((plugin: any) => (
          <a href={localePath(lang, `/plugins/${plugin.id.replace('official.', '')}/`)} class={`card plugin-card kind-${plugin.kind}`} data-kind={plugin.kind} data-search={`${plugin.display_name} ${plugin.id} ${plugin.summary} ${plugin.capabilities?.join(' ')}`}>
            <div class="plugin-card-header">
              <div class="plugin-icon" aria-hidden="true">
                <PluginIcon iconUrl={plugin.iconUrl} kind={plugin.kind} size={20} />
              </div>
              <div class="plugin-card-title">
                <h3 class="plugin-name">{plugin.display_name}</h3>
                <span class="plugin-id">{plugin.id}</span>
                <div class="plugin-badges">
                  {plugin.trust_level === 'official' && <span class="pill pill-official">Official</span>}
                  <span class="pill pill-brand plugin-kind">{kindLabels[plugin.kind] ?? plugin.kind}</span>
                </div>
              </div>
            </div>
            <p class="plugin-summary">{plugin.summary}</p>
            <div class="plugin-caps">
              {plugin.capabilities?.map((cap: string) => (
                <span class="pill">{cap}</span>
              ))}
            </div>
            <div class="plugin-stats">
              {plugin.templates && <span>{plugin.templates.length} template{plugin.templates.length !== 1 ? 's' : ''}</span>}
              {plugin.agents && <span>{plugin.agents.length} agent{plugin.agents.length !== 1 ? 's' : ''}</span>}
              {plugin.providers && <span>{plugin.providers.length} provider{plugin.providers.length !== 1 ? 's' : ''}</span>}
              {plugin.checks && <span>{plugin.checks.length} check{plugin.checks.length !== 1 ? 's' : ''}</span>}
              {plugin.policies && <span>{plugin.policies.length} polic{plugin.policies.length !== 1 ? 'ies' : 'y'}</span>}
              <span>v{plugin.plugin_version}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
<script is:inline>
  (function () {
    var cards = document.querySelectorAll('.plugin-card');
    var filters = document.querySelectorAll('.filter-btn');
    var count = document.getElementById('results-count');
    var activeKind = 'all';

    function applyFilter() {
      var visible = 0;
      cards.forEach(function (card) {
        var kind = card.getAttribute('data-kind');
        var show = activeKind === 'all' || kind === activeKind;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (count) {
        count.textContent = visible === cards.length ? '' : visible + ' plugin' + (visible !== 1 ? 's' : '');
      }
    }

    filters.forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeKind = btn.getAttribute('data-kind') || 'all';
        filters.forEach(function (b) {
          b.classList.toggle('filter-active', b === btn);
          b.classList.toggle('pill-brand', b === btn);
        });
        applyFilter();
      });
    });
  })();
</script>
</Base>

<style>
  .catalog-desc {
    font-size: 1.125rem;
    color: var(--re-text-secondary);
    max-width: 560px;
    line-height: 1.6;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--re-space-2);
    margin-bottom: var(--re-space-4);
  }

  .filter-btn {
    cursor: pointer;
    border: none;
    font-family: var(--re-font-sans);
    transition: background 0.15s, color 0.15s;
  }

  .filter-active {
    font-weight: 700;
  }

  .results-count {
    font-size: 0.8125rem;
    color: var(--re-text-muted);
    margin-bottom: var(--re-space-4);
    min-height: 1.2em;
  }

  .plugin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--re-space-5);
  }

  .plugin-card {
    display: flex;
    flex-direction: column;
    gap: var(--re-space-3);
    text-decoration: none;
    color: var(--re-text-primary);
    overflow: hidden;
  }

  .plugin-card:hover {
    text-decoration: none;
  }

  .plugin-card-header {
    display: flex;
    align-items: flex-start;
    gap: var(--re-space-3);
  }

  .plugin-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--re-brand-50);
    color: var(--re-brand-500);
    border-radius: var(--re-radius-md);
  }

  .plugin-name {
    font-size: 1.0625rem;
    line-height: 1.3;
  }

  .plugin-id {
    font-family: var(--re-font-mono);
    font-size: 0.75rem;
    color: var(--re-text-muted);
  }

  .plugin-badges {
    margin-left: auto;
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .plugin-card-title {
    min-width: 0;
  }

  .plugin-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }

  .pill-official {
    background: var(--re-brand-50);
    color: var(--re-brand-600);
    font-size: 0.6875rem;
  }

  .plugin-kind {
    font-size: 0.6875rem;
  }

  .plugin-summary {
    font-size: 0.875rem;
    color: var(--re-text-secondary);
    line-height: 1.5;
    flex: 1;
  }

  .plugin-caps {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .plugin-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--re-space-3);
    font-size: 0.75rem;
    color: var(--re-text-muted);
    padding-top: var(--re-space-2);
    border-top: 1px solid var(--re-border);
  }

  /* Kind-specific styling */
  .kind-template { border-left: 3px solid var(--re-kind-template); }
  .kind-template .plugin-icon { background: var(--re-kind-template-soft); color: var(--re-kind-template); }

  .kind-agent_runtime { border-left: 3px solid var(--re-kind-agent); }
  .kind-agent_runtime .plugin-icon { background: var(--re-kind-agent-soft); color: var(--re-kind-agent); }

  .kind-mcp_contribution { border-left: 3px solid var(--re-kind-mcp); }
  .kind-mcp_contribution .plugin-icon { background: var(--re-kind-mcp-soft); color: var(--re-kind-mcp); }

  .kind-policy { border-left: 3px solid var(--re-kind-policy); }
  .kind-policy .plugin-icon { background: var(--re-kind-policy-soft); color: var(--re-kind-policy); }

  .kind-remote_control { border-left: 3px solid var(--re-kind-remote); }
  .kind-remote_control .plugin-icon { background: var(--re-kind-remote-soft); color: var(--re-kind-remote); }

  @media (max-width: 640px) {
    .plugin-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
