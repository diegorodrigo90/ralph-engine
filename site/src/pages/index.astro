---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import FeatureTabs from '../components/FeatureTabs.astro';
import PluginGrid from '../components/PluginGrid.astro';
import GettingStarted from '../components/GettingStarted.astro';
const lang = 'en' as const;
---

<StarlightPage
  frontmatter={{
    title: 'Ralph Engine',
    description: 'The open-source runtime for agentic coding workflows.',
    template: 'splash',
    pagefind: false,
    head: [{ tag: 'style', content: '#_top { display: none; }' }],
    tableOfContents: false,
  }}
  hasSidebar={false}
>
  <Hero lang={lang} />
  <Features lang={lang} />
  <FeatureTabs lang={lang} />
  <PluginGrid lang={lang} />
  <GettingStarted lang={lang} />
</StarlightPage>
