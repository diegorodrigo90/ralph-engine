---
import type { Locale } from '../i18n/utils';
import { t, localePath, alternateLang } from '../i18n/utils';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../../../shared/design-tokens.css';
import '../styles/global.css';

interface Props {
  lang: Locale;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const pageTitle = title ? `${title} — Ralph Engine` : 'Ralph Engine — The runtime for agentic coding workflows';
const pageDesc = description ?? t(lang, 'site.description');
const altLang = alternateLang(lang);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const altPath = Astro.url.pathname.replace('/pt-br', '') || '/';
const altUrl = new URL(localePath(altLang, altPath), Astro.site);
---

<!doctype html>
<html lang={lang === 'pt-br' ? 'pt-BR' : 'en'} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={lang === 'en' ? canonicalUrl : altUrl} />
    <link rel="alternate" hreflang="pt-BR" href={lang === 'pt-br' ? canonicalUrl : altUrl} />
    <link rel="icon" type="image/svg+xml" href="/logo-icon.svg" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    {/* Pagefind search UI (loaded on demand) */}
    <link href="/_pagefind/pagefind-ui.css" rel="stylesheet" />

    {/* Theme boot — inline, runs before paint to prevent flash.
        Shared key "ralph-theme" synced with VitePress. */}
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('ralph-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    {/* Search modal */}
    <div class="search-modal" id="search-modal" aria-hidden="true" data-lang={lang}>
      <div class="search-modal-backdrop"></div>
      <div class="search-modal-content">
        <div id="pagefind-container"></div>
        <button class="search-modal-close" aria-label={lang === 'pt-br' ? 'Fechar busca' : 'Close search'} type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

    <script is:inline>
      (function () {
        var modal = document.getElementById('search-modal');
        var container = document.getElementById('pagefind-container');
        var btn = document.getElementById('search-btn');
        var close = modal?.querySelector('.search-modal-close');
        var backdrop = modal?.querySelector('.search-modal-backdrop');
        var loaded = false;

        function openSearch() {
          if (!modal) return;
          modal.setAttribute('aria-hidden', 'false');
          modal.classList.add('is-open');
          document.body.style.overflow = 'hidden';

          if (!loaded && container) {
            loaded = true;
            var script = document.createElement('script');
            script.src = '/_pagefind/pagefind-ui.js';
            script.onload = function () {
              var isptbr = modal.getAttribute('data-lang') === 'pt-br';
              new PagefindUI({
                element: '#pagefind-container',
                showSubResults: true,
                showImages: false,
                translations: isptbr ? {
                  placeholder: 'Buscar plugins e docs...',
                  zero_results: 'Nenhum resultado para [SEARCH_TERM]',
                  many_results: '[COUNT] resultados para [SEARCH_TERM]',
                  one_result: '[COUNT] resultado para [SEARCH_TERM]',
                  searching: 'Buscando [SEARCH_TERM]...',
                } : undefined,
              });
              setTimeout(function () {
                var input = container.querySelector('input');
                if (input) input.focus();
              }, 100);
            };
            document.head.appendChild(script);
          } else {
            setTimeout(function () {
              var input = container?.querySelector('input');
              if (input) input.focus();
            }, 50);
          }
        }

        function closeSearch() {
          if (!modal) return;
          modal.setAttribute('aria-hidden', 'true');
          modal.classList.remove('is-open');
          document.body.style.overflow = '';
        }

        if (btn) btn.addEventListener('click', openSearch);
        if (close) close.addEventListener('click', closeSearch);
        if (backdrop) backdrop.addEventListener('click', closeSearch);

        document.addEventListener('keydown', function (e) {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            if (modal?.classList.contains('is-open')) closeSearch();
            else openSearch();
          }
          if (e.key === 'Escape' && modal?.classList.contains('is-open')) closeSearch();
        });
      })();
    </script>

    {/* Copy to clipboard — works on all pages */}
    <script is:inline>
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('.copy-btn');
        if (!btn) return;
        var text = btn.getAttribute('data-copy');
        if (!text) return;
        navigator.clipboard.writeText(text).then(function () {
          btn.classList.add('copied');
          var feedback = document.querySelector('.copy-feedback');
          if (feedback) feedback.textContent = 'Copied!';
          setTimeout(function () {
            btn.classList.remove('copied');
            if (feedback) feedback.textContent = '';
          }, 2000);
        });
      });
    </script>
    <span class="copy-feedback" role="status" aria-live="polite" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);"></span>
    {/* Package manager preference persistence */}
    <script is:inline>
      (function () {
        var key = 'ralph-pkg-mgr';
        var saved = localStorage.getItem(key);
        // Map saved preference to radio index: cargo=0, npm=1, brew=2
        var map = { cargo: 0, npm: 1, brew: 2 };
        var names = ['cargo', 'npm', 'brew'];

        if (saved && map[saved] !== undefined) {
          // Restore: check the right radio in all install tab groups
          document.querySelectorAll('.tabs').forEach(function (tabs) {
            var radios = tabs.querySelectorAll('input[type="radio"]');
            var labels = tabs.querySelectorAll('.tab-list label');
            // Only apply to install tabs (3 tabs with cargo/npm/brew labels)
            if (radios.length === 3 && labels.length === 3) {
              var idx = map[saved];
              if (radios[idx]) radios[idx].checked = true;
            }
          });
        }

        // Save on change
        document.addEventListener('change', function (e) {
          var target = e.target;
          if (target.type !== 'radio') return;
          var tabs = target.closest('.tabs');
          if (!tabs) return;
          var radios = tabs.querySelectorAll('input[type="radio"]');
          if (radios.length !== 3) return;
          var idx = Array.from(radios).indexOf(target);
          if (names[idx]) localStorage.setItem(key, names[idx]);
        });
      })();
    </script>
  </body>
</html>
